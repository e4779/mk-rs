#!/usr/bin/env bash
# mk-rust pre-push hook — coverage ratchet.
#
# Runs cargo-llvm-cov and blocks the push if total line coverage falls
# below the baseline recorded in .coverage-baseline. If coverage grew,
# the baseline is automatically bumped (that's the "ratchet").
#
# Cost: ~15s on a warm build (full clean run ~3-5min; incremental ~15s).
# Pre-push, not pre-commit — pushes are rarer than commits and represent
# the "publishing to remote" moment, which is the right checkpoint.
#
# Why local (not just CI): see CONTRIBUTING.md "Tiered gates" and the
# local-first philosophy. Catch regressions in the flow, not a week later.
#
# Install:  git config core.hooksPath .githooks
# Bypass (emergency):  git push --no-verify
# Skip for a single push:  COVERAGE_SKIP=1 git push

# shellcheck source=./_common.sh
. "$(dirname "$0")/_common.sh"

# Allow ad-hoc skip (e.g. pushing a WIP branch, doc-only changes).
[ "${COVERAGE_SKIP:-0}" = "1" ] && { log_warn "COVERAGE_SKIP=1 — skipping coverage gate"; exit 0; }

ROOT="$(ws_root)"
BASELINE_FILE="$ROOT/.coverage-baseline"

# --- Refuse to run without baseline -------------------------------------
if [ ! -f "$BASELINE_FILE" ]; then
    log_warn "no .coverage-baseline file — skipping coverage gate"
    log_info "create one with: cargo llvm-cov --workspace --summary-only | grep TOTAL"
    exit 0
fi

BASELINE=$(cat "$BASELINE_FILE" | tr -dc '0-9.')
if [ -z "$BASELINE" ]; then
    log_warn ".coverage-baseline is empty — skipping coverage gate"
    exit 0
fi

section "pre-push: coverage ratchet (baseline ${BASELINE}%)"

# --- Optimization: skip when no Rust changes are being pushed -----------
# Read the commits being pushed (refs passed on stdin: <old> <new> <ref>).
# Use 'git log --name-only OLD..NEW' rather than 'git diff OLD..NEW' so that
# merge commits bringing in Rust changes via their second parent are detected
# (git diff A..B only sees the first-parent delta and can miss merged-in .rs).
RUST_CHANGED=0
while read -r REF_LINE; do
    # git pre-push stdin format (githooks docs):
    #   <local_ref> SP <local_sha> SP <remote_ref> SP <remote_sha>
    # We need REMOTE_SHA (what's currently on the remote) and LOCAL_SHA
    # (what we're pushing) to compute what's actually new for the remote.
    set -- $REF_LINE
    LOCAL_REF="$1"; LOCAL_SHA="$2"; REMOTE_REF="$3"; REMOTE_SHA="$4"
    # Branch deletion: remote had something, we're pushing 0000 (delete).
    [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ] && continue
    # New branch: remote has nothing (0000), so everything in LOCAL_SHA is new.
    if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
        RANGE="$LOCAL_SHA"
    else
        RANGE="${REMOTE_SHA}..${LOCAL_SHA}"
    fi
    # Use 'git log --name-only' rather than 'git diff' so merge commits that
    # bring in Rust changes via their second parent are also detected.
    if git log --name-only --pretty=format: "$RANGE" | sort -u | grep -qE '\.(rs|toml)$|^(Cargo\.lock|cliff\.toml)$'; then
        RUST_CHANGED=1
        break
    fi
done
[ "$RUST_CHANGED" = "0" ] && { log_info "no Rust/Cargo changes in push — skipping coverage gate"; exit 0; }

# --- Run coverage --------------------------------------------------------
# Delegate the pass/fail decision to cargo-llvm-cov's --fail-under-lines
# (it exits 1 when below threshold) instead of parsing the TOTAL row
# ourselves — earlier versions grabbed the regions % by mistake and called
# it line coverage, which silently inflated the baseline. cargo-llvm-cov
# owns the metric definition.
#
# Threshold = baseline − tolerance (mirror the CI mirror in
# .gitverse/workflows/ci.yml; scheduler/parser tests are mildly
# non-deterministic, producing ~0.04% jitter, so a 0.10% band absorbs noise
# without flapping).
TOLERANCE=0.10
THRESHOLD=$(awk "BEGIN { printf \"%.2f\", $BASELINE - $TOLERANCE }")

log_info "measuring coverage (cargo llvm-cov --workspace --summary-only --fail-under-lines $THRESHOLD)"
log_info "baseline $BASELINE%, fail-under-lines threshold $THRESHOLD% (baseline − $TOLERANCE jitter tolerance)"

# Capture full output for diagnostics, but rely on exit code for the gate.
if ! COV_OUTPUT=$(cd "$ROOT" && cargo llvm-cov --workspace --summary-only --fail-under-lines "$THRESHOLD" 2>&1); then
    log_fail "coverage regression: below $THRESHOLD% (baseline $BASELINE% − $TOLERANCE% tolerance)"
    printf '%s\n' "$COV_OUTPUT" | tail -20
    printf '\n'
    log_info "options:"
    log_info "  1. Add tests to cover the new/changed code, then push again."
    log_info "  2. If the drop is intentional (removed dead code, etc.), update baseline:"
    printf '       echo X.XX > .coverage-baseline && git add .coverage-baseline\n'
    log_info "     where X.XX is the new TOTAL Lines % from the output above."
    log_info "  3. Bypass this once (emergency only): COVERAGE_SKIP=1 git push"
    hook_die
fi

# Gate passed. Check for improvement to ratchet the baseline up.
# Parse the TOTAL row's LINES coverage (column after the 2 'missed' counts
# following the Lines count). Print only the LINES % — robust against column
# drift by anchoring on the label.
CURRENT=$(printf '%s\n' "$COV_OUTPUT" | awk '
    /^TOTAL/ {
        # Columns: TOTAL Regions MissedRegions Regions% Functions MissedFuncs Func% Lines MissedLines Lines%
        # The 3rd %-field is Lines coverage (Regions=1, Functions=2, Lines=3).
        # When branches are enabled there would be a 4th, but we run without
        # branch coverage, so Lines is always #3.
        pct_count = 0
        for (i = 1; i <= NF; i++) {
            if ($i ~ /%$/) {
                pct_count++
                if (pct_count == 3) { print $i; exit }
            }
        }
    }' | tr -dc '0-9.')

if [ -n "$CURRENT" ]; then
    IMPROVED=$(awk "BEGIN { print ($CURRENT > $BASELINE + $TOLERANCE) ? 1 : 0 }")
    if [ "$IMPROVED" = "1" ]; then
        log_pass "lines coverage improved: ${BASELINE}% → ${CURRENT}%   (ratcheting baseline up)"
        printf '%.2f\n' "$CURRENT" > "$BASELINE_FILE"
        log_info "baseline bumped in .coverage-baseline — commit it: git add .coverage-baseline"
    else
        log_pass "lines coverage within tolerance of baseline (${BASELINE}%, measured ${CURRENT}%)"
    fi
else
    log_pass "coverage gate passed (could not parse Lines % for ratchet — baseline unchanged)"
fi

section "coverage gate passed"
exit 0
